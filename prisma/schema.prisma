generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  price        Float
  comparePrice Float?
  stock        Int      @default(0)
  category     String
  game         String   @default("pokemon") // 'pokemon' | 'one-piece'
  images       String[]
  grade        String?
  grader       String?
  featured     Boolean  @default(false)
  active       Boolean  @default(true)
  tags         String[]
  // Vendor ownership — which team member owns this stock. Nullable for
  // legacy/imported items but new products always assigned via API.
  // Only the owning vendor can edit/delete. Superadmin can view all.
  vendorId     String?
  vendor       AdminUser? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([game])
  @@index([featured])
  @@index([active])
  @@index([vendorId])
}

model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text")
  label     String?
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  alt       String?
  createdAt DateTime @default(now())
}

model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String?
  // 'superadmin' = full access (Bhumit); 'vendor' = sees only own products + payouts
  role           String    @default("vendor")
  // Platform's cut as a percent of vendor sales (0-100). Only relevant for
  // role='vendor'. Set to 0 for free consignment, 10 for standard, etc.
  commissionRate Float     @default(0)
  // Free-form text for payout details — "PayPal: foo@bar.com", "Bank: 12-34-56
  // / 12345678", "Cash". Superadmin reads this on the payouts page.
  payoutNotes    String?   @db.Text
  // Optional avatar shown in admin sidebar + member list.
  avatarUrl      String?
  // Disable a member without deleting — their products stay live but they
  // can't log in or create new stock.
  active         Boolean   @default(true)

  // ─── Two-factor authentication (TOTP) ─────────────────────────────────
  // Encrypted secret (AES-GCM, key derived from ADMIN_JWT_SECRET). Null
  // until the user starts enrolment.
  totpSecret     String?   @db.Text
  // True only after the first valid 6-digit code is submitted — until then
  // the secret is "pending" and not honoured at login.
  totpEnabled    Boolean   @default(false)
  // 10 single-use recovery codes (bcrypt-hashed). Used to log in if the
  // authenticator is lost; each consumed code is rotated to a "used" marker.
  totpRecoveryCodes String[] @default([])

  createdAt      DateTime  @default(now())
  lastLogin      DateTime?
  products       Product[]
  orderItems     OrderItem[]
  passkeys       Passkey[]
}

// ─── WebAuthn / passkey credentials ─────────────────────────────────────
// One row per registered credential. A single user can have many: laptop
// biometric, phone, hardware key, etc. counter is the WebAuthn signature
// counter (BigInt because most authenticators emit 32-bit unsigned values).
model Passkey {
  id              String    @id @default(cuid())
  adminUserId     String
  adminUser       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  // Base64URL-encoded credential ID returned by the authenticator. Indexed
  // so login can look up the user by credentialID returned in the assertion.
  credentialID    String    @unique
  // Raw public key bytes (CBOR-encoded COSE key) used to verify assertions.
  publicKey       Bytes
  // WebAuthn counter — must monotonically increase on every assertion.
  // Stored as BigInt to safely hold values from common 32-bit authenticators.
  counter         BigInt    @default(0)
  // Comma-separated transports hint ("usb", "ble", "internal", "nfc", "hybrid").
  transports      String?
  // User-friendly name set at registration time ("Bhumit's iPhone", "YubiKey").
  name            String
  // Whether this credential is "discoverable" (resident key) so the user can
  // sign in without typing their email first.
  isDiscoverable  Boolean   @default(true)
  // Optional device-type marker reported by the browser ("platform" or
  // "cross-platform"). Used purely for UI icon hints.
  deviceType      String?
  // Whether the credential is backed up to the user's cloud (Apple/Google
  // password manager). Informational, used to surface to the user.
  backedUp        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([adminUserId])
}

model Order {
  id               String      @id @default(cuid())
  email            String
  name             String
  phone            String?
  address          String?
  status           String      @default("pending")
  total            Float
  notes            String?
  shippingLine1    String?
  shippingLine2    String?
  shippingCity     String?
  shippingPostcode String?
  shippingCountry  String?     @default("GB")
  shippingMethod   String?
  shippingCost     Float?      @default(0)
  trackingNumber   String?
  trackingCarrier  String?
  // Discount applied at checkout (snapshot — preserves history if discount edited later)
  discountCode     String?
  discountAmount   Float?      @default(0)
  // Optional link to registered customer (guest orders leave this null)
  userId           String?
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([status])
  @@index([email])
  @@index([userId])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  price        Float
  quantity     Int
  // Snapshot of who owned the product at sale time, plus the payout math.
  // Kept on the line item (not derived) so historical payouts don't shift
  // if a product is later reassigned or a commission rate changes.
  vendorId     String?
  vendor       AdminUser? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorPayout Float      @default(0)   // what the vendor is owed for this line
  platformFee  Float      @default(0)   // what the platform retained
  // Payout lifecycle for the per-vendor totals page. Null until superadmin
  // marks it paid; payoutPaidAt records when, payoutNote captures method.
  payoutPaidAt DateTime?
  payoutNote   String?

  @@index([vendorId])
  @@index([payoutPaidAt])
}

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]
  active    Boolean        @default(true)
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
}

model ShippingRate {
  id         String       @id @default(cuid())
  zoneId     String
  zone       ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name       String
  price      Float
  minDays    Int          @default(1)
  maxDays    Int          @default(5)
  freeAbove  Float?
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
}

model Discount {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // 'percentage' | 'fixed'
  value     Float     // e.g. 10 for 10% or £10 off
  minOrder  Float?    // minimum order value to apply
  maxUses   Int?      // null = unlimited
  uses      Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Review {
  id                String   @id @default(cuid())
  name              String
  location          String?
  rating            Int      @default(5)   // 1-5
  title             String?  // optional short headline
  body              String   @db.Text
  productRef        String?  // legacy free-text product name reference
  productId         String?  // proper FK link to Product (preferred)
  userId            String?  // who wrote it (nullable for legacy + admin-seeded)
  verifiedPurchase  Boolean  @default(false)
  approved          Boolean  @default(false)
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([approved])
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String   @default("collecttcg")
  status    String   // "success" | "error" | "partial"
  message   String?
  created   Int      @default(0)   // products created
  updated   Int      @default(0)   // products updated
  skipped   Int      @default(0)
  duration  Int      @default(0)   // ms
  createdAt DateTime @default(now())
}

model SellSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  game        String   // 'pokemon' | 'one-piece' | 'mixed'
  details     String   @db.Text
  estimate    String?  // collector's estimated value (free-text)
  images      String[]
  status      String   @default("new") // 'new' | 'reviewing' | 'offered' | 'accepted' | 'declined' | 'closed'
  adminNotes  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  phone         String?
  marketingOptIn Boolean  @default(false)
  // Default shipping address (saved at checkout for convenience)
  addressLine1  String?
  addressLine2  String?
  city          String?
  postcode      String?
  country       String?   @default("GB")
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?
  orders        Order[]
  wishlist      Wishlist[]
  stockNotifications StockNotification[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model StockNotification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  email      String    // Snapshot of user's email at subscribe time (in case account is deleted)
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?

  @@unique([userId, productId])
  @@index([productId])
  @@index([notifiedAt])
}
