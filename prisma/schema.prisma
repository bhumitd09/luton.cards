generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  // Base price — used when the product has no per-variant pricing. When
  // variants exist they take precedence (each has its own price + stock).
  price        Float
  comparePrice Float?
  stock        Int      @default(0)
  category     String
  game         String   @default("pokemon") // 'pokemon' | 'one-piece'
  images       String[]
  grade        String?
  grader       String?
  // Card condition for raw (ungraded) singles — NM / LP / MP / HP / DMG.
  // Shown on the storefront card instead of the stock badge. Graded slabs use
  // grade/grader instead; products with per-condition variants use those.
  condition    String?
  featured     Boolean  @default(false)
  active       Boolean  @default(true)
  tags         String[]
  // Vendor ownership — which team member owns this stock. Nullable for
  // legacy/imported items but new products always assigned via API.
  // Only the owning vendor can edit/delete. Superadmin can view all.
  vendorId     String?
  vendor       AdminUser? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  // Card-condition variants (Near Mint, Lightly Played, etc.) + foil.
  // Empty for legacy single-SKU products — those keep using the base
  // price/stock above. When non-empty, the storefront shows a selector
  // and orders carry the chosen variantId.
  variants     ProductVariant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([game])
  @@index([featured])
  @@index([active])
  @@index([vendorId])
}

// One row per (productId, condition, foil) combination. Each has its own
// price + stock so a Near Mint Holofoil can cost more than a Damaged Normal
// of the same card. Unique constraint stops accidental duplicates.
model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // 'near-mint' | 'lightly-played' | 'moderately-played' | 'heavily-played' | 'damaged'
  condition  String
  // 'normal' | 'holofoil' | 'reverse-holofoil'. Optional — many cards
  // only exist in one finish.
  foil       String?
  price      Float
  stock      Int      @default(0)
  sku        String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orderItems OrderItem[]

  @@unique([productId, condition, foil])
  @@index([productId])
}

model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text")
  label     String?
  updatedAt DateTime @updatedAt
}

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  size       Int
  mimeType   String
  alt        String?
  // Who uploaded it — for vendor scoping. Null for legacy/system uploads
  // (visible to superadmin only). Vendors see + manage only their own.
  vendorId   String?
  createdAt  DateTime @default(now())

  @@index([vendorId])
}

model AdminUser {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  name           String?
  // 'superadmin' = full access (Bhumit); 'vendor' = sees only own products + payouts
  role           String    @default("vendor")
  // Platform's cut as a percent of vendor sales (0-100). Only relevant for
  // role='vendor'. Set to 0 for free consignment, 10 for standard, etc.
  commissionRate Float     @default(0)
  // Free-form text for payout details — "PayPal: foo@bar.com", "Bank: 12-34-56
  // / 12345678", "Cash". Superadmin reads this on the payouts page.
  payoutNotes    String?   @db.Text
  // Optional avatar shown in admin sidebar + member list.
  avatarUrl      String?
  // Disable a member without deleting — their products stay live but they
  // can't log in or create new stock.
  active         Boolean   @default(true)

  // ─── Two-factor authentication (TOTP) ─────────────────────────────────
  // Encrypted secret (AES-GCM, key derived from ADMIN_JWT_SECRET). Null
  // until the user starts enrolment.
  totpSecret     String?   @db.Text
  // True only after the first valid 6-digit code is submitted — until then
  // the secret is "pending" and not honoured at login.
  totpEnabled    Boolean   @default(false)
  // 10 single-use recovery codes (bcrypt-hashed). Used to log in if the
  // authenticator is lost; each consumed code is rotated to a "used" marker.
  totpRecoveryCodes String[] @default([])

  // ─── Session revocation ───────────────────────────────────────────────
  // Bumped on password change or "sign out everywhere". JWT payload carries
  // the token's version at sign time; getAdminFromRequest compares against
  // this column and rejects stale tokens. Enables real session revocation
  // without a server-side session store.
  tokenVersion   Int       @default(0)

  // ─── Password reset ───────────────────────────────────────────────────
  // SHA-256 hash of the single-use reset token (raw token only ever lives in
  // the emailed link). Cleared after use or expiry.
  resetTokenHash   String?
  resetTokenExpiry DateTime?

  createdAt      DateTime  @default(now())
  lastLogin      DateTime?
  products       Product[]
  orderItems     OrderItem[]
  passkeys       Passkey[]
}

// ─── WebAuthn / passkey credentials ─────────────────────────────────────
// One row per registered credential. A single user can have many: laptop
// biometric, phone, hardware key, etc. counter is the WebAuthn signature
// counter (BigInt because most authenticators emit 32-bit unsigned values).
model Passkey {
  id              String    @id @default(cuid())
  adminUserId     String
  adminUser       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  // Base64URL-encoded credential ID returned by the authenticator. Indexed
  // so login can look up the user by credentialID returned in the assertion.
  credentialID    String    @unique
  // Raw public key bytes (CBOR-encoded COSE key) used to verify assertions.
  publicKey       Bytes
  // WebAuthn counter — must monotonically increase on every assertion.
  // Stored as BigInt to safely hold values from common 32-bit authenticators.
  counter         BigInt    @default(0)
  // Comma-separated transports hint ("usb", "ble", "internal", "nfc", "hybrid").
  transports      String?
  // User-friendly name set at registration time ("Bhumit's iPhone", "YubiKey").
  name            String
  // Whether this credential is "discoverable" (resident key) so the user can
  // sign in without typing their email first.
  isDiscoverable  Boolean   @default(true)
  // Optional device-type marker reported by the browser ("platform" or
  // "cross-platform"). Used purely for UI icon hints.
  deviceType      String?
  // Whether the credential is backed up to the user's cloud (Apple/Google
  // password manager). Informational, used to surface to the user.
  backedUp        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  @@index([adminUserId])
}

model Order {
  id               String      @id @default(cuid())
  email            String
  name             String
  phone            String?
  address          String?
  status           String      @default("pending")
  total            Float
  notes            String?
  shippingLine1    String?
  shippingLine2    String?
  shippingCity     String?
  shippingPostcode String?
  shippingCountry  String?     @default("GB")
  shippingMethod   String?
  shippingCost     Float?      @default(0)
  trackingNumber   String?
  trackingCarrier  String?
  // Discount applied at checkout (snapshot — preserves history if discount edited later)
  discountCode     String?
  discountAmount   Float?      @default(0)
  // Optional link to registered customer (guest orders leave this null)
  userId           String?
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Stripe Checkout session id, recorded at session-create time. The webhook
  // verifies that the incoming session id matches this column before flipping
  // the order to 'paid' — stops attackers from creating a £1 session whose
  // metadata.orderId points at someone else's expensive pending order.
  stripeSessionId  String?
  // Provider-agnostic payment fields. paymentProvider is 'stripe' | 'square'
  // (whichever processed this order); paymentRef is that provider's
  // session/payment id. stripeSessionId is kept for back-compat + the existing
  // Stripe webhook's provenance check, but new code should read paymentRef so
  // adding Square doesn't require schema changes.
  paymentProvider  String?
  paymentRef       String?
  // Refund tracking. refundedAmount accumulates partial refunds; refundedAt
  // stamps the most recent refund. A 'cancelled' status + non-null refund
  // means money went back.
  refundedAmount   Float?      @default(0)
  refundedAt       DateTime?
  // True for admin-created orders (phone / in-person / marketplace) so they
  // can be told apart from customer web checkouts.
  isManual         Boolean     @default(false)
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([status])
  @@index([email])
  @@index([userId])
  @@index([stripeSessionId])
  @@index([paymentRef])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  price        Float
  quantity     Int
  // Variant link + condition/foil snapshot. variantId is null for legacy
  // single-SKU orders. The snapshot strings preserve the condition label
  // even if the variant row is later deleted.
  variantId        String?
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantCondition String?
  variantFoil      String?
  // Snapshot of who owned the product at sale time, plus the payout math.
  // Kept on the line item (not derived) so historical payouts don't shift
  // if a product is later reassigned or a commission rate changes.
  vendorId     String?
  vendor       AdminUser? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorPayout Float      @default(0)   // what the vendor is owed for this line
  platformFee  Float      @default(0)   // what the platform retained
  // Payout lifecycle for the per-vendor totals page. Null until superadmin
  // marks it paid; payoutPaidAt records when, payoutNote captures method.
  payoutPaidAt DateTime?
  payoutNote   String?

  @@index([vendorId])
  @@index([payoutPaidAt])
  @@index([variantId])
}

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]
  active    Boolean        @default(true)
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
}

model ShippingRate {
  id         String       @id @default(cuid())
  zoneId     String
  zone       ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name       String
  price      Float
  minDays    Int          @default(1)
  maxDays    Int          @default(5)
  freeAbove  Float?
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
}

model Discount {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // 'percentage' | 'fixed'
  value     Float     // e.g. 10 for 10% or £10 off
  minOrder  Float?    // minimum order value to apply
  maxUses   Int?      // null = unlimited
  uses      Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Review {
  id                String   @id @default(cuid())
  name              String
  location          String?
  rating            Int      @default(5)   // 1-5
  title             String?  // optional short headline
  body              String   @db.Text
  productRef        String?  // legacy free-text product name reference
  productId         String?  // proper FK link to Product (preferred)
  userId            String?  // who wrote it (nullable for legacy + admin-seeded)
  verifiedPurchase  Boolean  @default(false)
  approved          Boolean  @default(false)
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([approved])
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String   @default("collecttcg")
  status    String   // "success" | "error" | "partial"
  message   String?
  created   Int      @default(0)   // products created
  updated   Int      @default(0)   // products updated
  skipped   Int      @default(0)
  duration  Int      @default(0)   // ms
  createdAt DateTime @default(now())
}

model SellSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  game        String   // 'pokemon' | 'one-piece' | 'mixed'
  details     String   @db.Text
  estimate    String?  // collector's estimated value (free-text)
  images      String[]
  status      String   @default("new") // 'new' | 'reviewing' | 'offered' | 'accepted' | 'declined' | 'closed'
  adminNotes  String?  @db.Text
  // Concrete £ offer the admin makes for the collection. Set when status
  // moves to 'offered'; emailed to the seller.
  offerAmount Float?
  offerSentAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  phone         String?
  marketingOptIn Boolean  @default(false)
  // Default shipping address (saved at checkout for convenience)
  addressLine1  String?
  addressLine2  String?
  city          String?
  postcode      String?
  country       String?   @default("GB")
  // Session revocation — see AdminUser.tokenVersion.
  tokenVersion  Int       @default(0)
  // Password reset — SHA-256 hash of the single-use token, cleared after use.
  resetTokenHash   String?
  resetTokenExpiry DateTime?
  // Email verification — true once the user clicks the verify link. Until then
  // no past guest orders are attached to the account (signup emails are
  // unverified, so email-matching before verification would leak order history
  // + shipping addresses). verifyTokenHash is the SHA-256 of the single-use
  // verify token, cleared once consumed.
  emailVerified     Boolean   @default(false)
  verifyTokenHash   String?
  verifyTokenExpiry DateTime?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?
  orders        Order[]
  wishlist      Wishlist[]
  stockNotifications StockNotification[]
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model StockNotification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  email      String    // Snapshot of user's email at subscribe time (in case account is deleted)
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?

  @@unique([userId, productId])
  @@index([productId])
  @@index([notifiedAt])
}

// ─── Customer profiles ──────────────────────────────────────────────────
// Keyed by email so it covers BOTH registered users and guest checkouts.
// Lets the admin add notes/tags and block an email from checkout. The
// customers admin page joins this onto the order rollup.
model CustomerProfile {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  adminNotes String?  @db.Text
  tags       String[]
  // When true, /api/orders refuses new orders for this email.
  blocked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([blocked])
}

// ─── Contact form inbox ─────────────────────────────────────────────────
// Replaces stuffing enquiries into the Content table. status: new|read|archived.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ─── CMS pages (FAQ / Privacy / Terms / Cookies …) ──────────────────────
// Editable standalone pages so legal/help copy changes without a deploy.
// `body` is markdown/HTML rendered by the public page.
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String   @db.Text
  published Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([slug])
}

// ─── Admin notifications (in-app bell feed) ─────────────────────────────
// A single store-wide feed surfaced in the back-office topbar so the team
// can see at a glance when something happens (a sale, a refund, low stock,
// a new contact message). `read` is global (small team) — marking read
// clears it for everyone. `href` deep-links to the relevant admin page.
model Notification {
  id        String   @id @default(cuid())
  type      String   // 'sale' | 'refund' | 'order' | 'low-stock' | 'contact' | …
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
